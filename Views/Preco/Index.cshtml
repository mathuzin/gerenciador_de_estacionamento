@model List<TabelaPrecoModel>

<form asp-action="Cadastrar" method="post">
    <div class="row">
        <div class="col">
            <label>Valor hora inicial:</label>
            <input class="form-control" type="number" step="0.01" name="valor_hora_inicial" />
        </div>
        <div class="col">
            <label>Valor hora adicional:</label>
            <input class="form-control" type="number" step="0.01" name="valor_hora_adicional" />
        </div>

        <div class="col">
            <label>Início vigência:</label>
            <input class="form-control" type="date" name="data_inicio" />
        </div>

        <div class="col">
            <label>Fim vigência:</label>
            <input class="form-control" type="date" name="data_fim" />
        </div>

        <div class="col">
            <button class="btn btn-light" type="submit" style="margin-top: 24px;">Cadastrar</button>
        </div>
        
    </div>
<div class="row">
        <div class="col">
            <table class="table table-dark table-striped">
                <tr>
                    <td>Hora Inicial</td>
                    <td>Hora Adicional</td>
                    <td>Início</td>
                    <td>Fim</td>
                </tr>
                @foreach (var preco in Model)
                {
                    <tr>
                        <td>@preco.valor_inicial</td>
                        <td>@preco.valor_adicional</td>
                        <td>@preco.data_inicio.ToShortDateString()</td>
                        <td>@preco.data_fim.ToShortDateString()</td>
                    </tr>
                }
            </table>
        </div>
    </div>
</form>
